      "date": { "value": "2024-08-1?", "confidence": 0.55, "needs_review": true },
      "row_confidence": 0.95,
      "expected": "drop",
      "expected_reason_substring": "date"
    },
    {
      "id": "needs_review_drops_via_field_confidence",

{
  "description": "Cross-language parity fixture for the trust-gate filter (filter_confirmed_doses in Python, filterConfirmedDoses in TS). The `cases` array is exercised by BOTH implementations and they MUST agree on every entry. The `ts_only_cases` array exercises TS-side-only semantics (the row.source field that has no Python schema analogue) — TS replays it; Python ignores it.",
  "threshold": 0.85,
  "cases": [
    {
      "id": "all_high_confidence_admitted",
      "summary": "Both required fields confident; row admitted.",
      "antigen": { "value": "BCG", "confidence": 0.95, "needs_review": false },
      "date": { "value": "2024-01-01", "confidence": 0.95, "needs_review": false },
      "row_confidence": 0.95,
      "expected": "admit"
    },
    {
      "id": "antigen_below_threshold_dropped",
      "summary": "Antigen field below threshold drops with an antigen-cited reason.",
      "antigen": { "value": "Rougeole", "confidence": 0.62, "needs_review": true },
      "date": { "value": "2023-09-15", "confidence": 0.95, "needs_review": false },
      "row_confidence": 0.95,
      "expected": "drop",
      "expected_reason_substring": "antigen"
    },
    {
      "id": "date_below_threshold_dropped",
      "summary": "Date field below threshold drops with a date-cited reason.",

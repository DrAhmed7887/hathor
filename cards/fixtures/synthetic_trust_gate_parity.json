      "row_confidence": 1.0,
      "expected": "admit"
    },
    {
      "id": "threshold_inclusivity",
      "summary": "Confidence exactly at the threshold passes (>= rule, not >).",
      "antigen": { "value": "Hexyon", "confidence": 0.85, "needs_review": false },
      "date": { "value": "2024-08-15", "confidence": 0.85, "needs_review": false },
      "row_confidence": 0.85,
      "expected": "admit"
    },
    {
      "id": "clinician_confirmed_admits_even_below_threshold",

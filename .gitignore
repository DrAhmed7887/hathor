# Commit 8 — FHIR Provenance override sink. Per-process append-only JSONL;
# production migrates to durable storage. Not a source artifact.
evaluation/provenance_log.jsonl

# Scratch / local experiments
/scratch/

# Internal build tracking (never commit)
/internal/

# Vaccination card images — dev-only test fixtures. Many are under
# copyright (WHO reports, published papers, MoH materials, real patient
# cards) and should not be redistributed through the repo. Real-card
# binaries and any ground-truth derived from them stay local only.
/cards/*
!/cards/.gitkeep
!/cards/README.md
!/cards/demo.jpg
!/cards/phase_d_demo.jpg
!/cards/fixtures/
/cards/fixtures/*
!/cards/fixtures/synthetic_*.json
!/cards/fixtures/README.md
!/cards/fixtures/synthetic_vaccination_cards/
!/cards/fixtures/synthetic_vaccination_cards/**

# Defence in depth: the blanket /cards/* rule above already excludes
# cards/private/, but making this explicit keeps future whitelist
# edits from accidentally admitting a real-card path. Private cards
# (e.g. local developer validation against real patient images) never
# belong in git, and their derived ground truth does not either.
/cards/private/
/cards/private/**

# Out-of-tree research scratch from parallel AI tools — kept locally
# for reference but not committed (proprietary or not Hathor-attributable).
/Claude Hackathon/

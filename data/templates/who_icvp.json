{
  "template_id": "who_icvp_international_certificate",
  "country": "INT",
  "card_type": "international_certificate_of_vaccination_or_prophylaxis",
  "version": "0.1",
  "is_synthetic_derived": true,
  "source_notes": "Synthetic schema for the WHO/IHR International Certificate of Vaccination or Prophylaxis (ICVP) card layout — traveller-card form factor as published by WHO under IHR (2005). No real traveller cards, no real passport numbers, no real stamps, no WHO endorsement of this template is implied. Used to drive review-workflow demonstration only. Card images generated by this project carry the synthetic-record disclosure stamp.",
  "synthetic_disclosure_stamp": "SYNTHETIC TEST RECORD — NOT VALID FOR TRAVEL",
  "header_fields": [
    {"id": "name", "label": "Surname / Given names", "required": true},
    {"id": "date_of_birth", "label": "Date of birth", "required": true, "format": "YYYY-MM-DD"},
    {"id": "sex", "label": "Sex", "required": false, "values": ["F", "M", "X"]},
    {"id": "nationality", "label": "Nationality", "required": false},
    {"id": "passport_or_travel_document_number", "label": "Passport / travel document #", "required": false, "synthetic_only": true}
  ],
  "vaccine_row_fields": [
    {"id": "disease_or_condition", "label": "Disease or condition", "required": true},
    {"id": "vaccine_or_prophylaxis", "label": "Vaccine or prophylaxis", "required": true},
    {"id": "date_administered", "label": "Date administered", "required": true, "format": "YYYY-MM-DD"},
    {"id": "clinician_signature_status", "label": "Clinician signature / status", "required": false},
    {"id": "manufacturer", "label": "Manufacturer", "required": false},
    {"id": "batch_number", "label": "Batch / lot number", "required": false},
    {"id": "valid_from", "label": "Certificate valid from", "required": false, "format": "YYYY-MM-DD"},
    {"id": "valid_until", "label": "Certificate valid until", "required": false, "format": "YYYY-MM-DD"},
    {"id": "official_stamp", "label": "Official centre stamp (placeholder)", "required": false}
  ],
  "common_traveller_vaccines": [
    {"disease": "Yellow fever", "antigen_synonyms": ["YellowFever", "YF", "Stamaril"]},
    {"disease": "Poliomyelitis", "antigen_synonyms": ["OPV", "IPV", "Polio"]},
    {"disease": "Meningococcal disease", "antigen_synonyms": ["MenACWY", "Menveo", "Nimenrix"]},
    {"disease": "COVID-19", "antigen_synonyms": ["COVID-19", "Comirnaty", "Spikevax"]},
    {"disease": "Cholera", "antigen_synonyms": ["Cholera", "Dukoral"]},
    {"disease": "Typhoid", "antigen_synonyms": ["Typhoid", "Typhim Vi"]}
  ],
  "review_posture": "Each vaccine row is treated as a vaccination event. Unknown disease/vaccine names are surfaced for clinician review rather than silently mapped or dropped. Manufacturer and batch travel as metadata. Validity windows are recorded but not used to gate engine reconciliation in this demo."
